{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AudioPAC",
  "version": "0.5.1",
  "identifier": "com.audiopac.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "AudioPAC",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "nsis", "msi"],
    "category": "Medical",
    "shortDescription": "Evaluación del Procesamiento Auditivo Central",
    "longDescription": "AudioPAC es un software clínico para la evaluación del Procesamiento Auditivo Central. Implementa los tests DPS (Duration Pattern Sequence) y PPS (Pitch Pattern Sequence) con parámetros totalmente configurables para uso clínico e investigación.",
    "copyright": "Copyright © 2026 AudioPAC",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": ["es-ES", "en-US"]
      },
      "nsis": {
        "languages": ["Spanish", "English"],
        "displayLanguageSelector": true
      }
    }
  }
}
