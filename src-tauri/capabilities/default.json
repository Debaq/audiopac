{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "AudioPAC default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-maximize",
    "core:window:allow-minimize",
    "core:window:allow-close",
    {
      "identifier": "sql:default",
      "allow": [
        { "path": "sqlite:audiopac.db" }
      ]
    },
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-write-file",
    "fs:allow-read-file",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "fs:allow-app-write-recursive",
    "fs:allow-app-read-recursive",
    "fs:allow-app-meta-recursive",
    "os:default",
    "process:default",
    "process:allow-restart",
    "opener:default",
    { "identifier": "opener:allow-open-url", "allow": [ { "url": "https://*" }, { "url": "http://*" } ] },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://raw.githubusercontent.com/" },
        { "url": "https://cdn.jsdelivr.net/" },
        { "url": "https://github.com/" },
        { "url": "https://objects.githubusercontent.com/" },
        { "url": "https://release-assets.githubusercontent.com/" },
        { "url": "https://codeload.github.com/" }
      ]
    }
  ]
}
